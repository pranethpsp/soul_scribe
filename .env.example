# ── LLM Keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=soulscribe_secret

# ── Langfuse (LLM Observability) ─────────────────────────────────────
# Get these from http://localhost:3001 after first login
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_NEXTAUTH_SECRET=changeme_at_least_32_characters_long
LANGFUSE_SALT=changeme_salt

# ── Admin Panel ───────────────────────────────────────────────────────
# Set VITE_ADMIN_MODE=true to show Knowledge Vault admin panel in UI
VITE_ADMIN_MODE=false
ADMIN_SECRET=dev_admin_secret

# ── Environment ───────────────────────────────────────────────────────
ENVIRONMENT=development
